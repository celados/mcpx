{
	"compilerOptions": {
		"target": "ES2024",
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"types": ["bun"],
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
