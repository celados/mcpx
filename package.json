{
	"name": "mcpx",
	"version": "0.9.11",
	"license": "MIT",
	"bin": {
		"mcpx": "./src/main.ts"
	},
	"type": "module",
	"scripts": {
		"build": "./scripts/build.sh",
		"check": "bun run typecheck && bun test && bunx oxfmt --check package.json tsconfig.json README.md .gitignore .oxfmtrc.json src tests skills docs",
		"format": "bunx oxfmt package.json tsconfig.json README.md .gitignore .oxfmtrc.json src tests skills docs",
		"typecheck": "tsgo --project tsconfig.json --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@valibot/to-json-schema": "^1.6.0",
		"argc": "github:ethan-huo/argc#v6.0.0",
		"valibot": "^1.3.1",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"@typescript/native-preview": "^7.0.0-dev.20260421.2",
		"oxfmt": "^0.46.0",
		"typescript": "npm:@typescript/typescript6@^6.0.0"
	}
}
